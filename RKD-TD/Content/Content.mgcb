
#----------------------------- Global Properties ----------------------------#

/outputDir:bin/$(Platform)
/intermediateDir:obj/$(Platform)
/platform:Windows
/config:
/profile:Reach
/compress:False

#-------------------------------- References --------------------------------#


#---------------------------------- Content ---------------------------------#

#begin configs/enemyconfig.xml
/copy:configs/enemyconfig.xml

#begin configs/turretconfig.xml
/copy:configs/turretconfig.xml

#begin fonts/font-atlas-definition.xml
/copy:fonts/font-atlas-definition.xml

#begin fonts/main_menu_btn_text.spritefont
/importer:FontDescriptionImporter
/processor:FontDescriptionProcessor
/processorParam:PremultiplyAlpha=True
/processorParam:TextureFormat=Compressed
/build:fonts/main_menu_btn_text.spritefont

#begin fonts/main_title.spritefont
/importer:FontDescriptionImporter
/processor:FontDescriptionProcessor
/processorParam:PremultiplyAlpha=True
/processorParam:TextureFormat=Compressed
