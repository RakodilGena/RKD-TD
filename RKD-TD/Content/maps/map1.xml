<?xml version="1.0" encoding="utf-8"?>
<Map>
    <Tileset region="0 0 900 360" tileWidth="180" tileHeight="180">images/game/map1-tiles-atlas</Tileset>
    <Tiles> <!-- 11x6 -->
        00 00 00 00 00 00 00 00 00 03 00
        00 02 02 02 02 02 00 03 03 03 00
        00 02 00 00 00 02 00 03 00 02 02
        02 02 00 02 02 02 00 03 00 02 00
        00 00 00 02 00 00 02 06 02 02 00
        00 00 00 02 02 02 02 03 00 00 00
    </Tiles>

    <GameObjectsAtlas>images/game/game-objects-atlas-definition.xml</GameObjectsAtlas>

    <Health textureAlias="heart_100">15</Health>
    <Coins textureAlias="coin_100">400</Coins>
    <Portals textureAlias="portal_200">10,2;0,3</Portals>


    <Spawner totalWaves="20" pauseBetweenWaves="5">
        <Enemies> <!-- Soldier, Speedster, Tank, Swarm, BOSS??? -->
            <Enemy alias="soldier"
                   health="100"
                   speed="200"
                   cost="100"
                   reward="50"
                   damage="1"
                   animationAlias="soldier-animation"
                   size="140;140"/> <!--textureAlias="soldier"-->

        </Enemies>

        <Waves>
            <!--The waves from here are hardcoded to better introduce them to the player-->
            <Wave spawnTime="10">
                soldier:10
            </Wave>
            <Wave spawnTime="10">
                soldier:10
            </Wave>
        </Waves>

        <WavesGenerator
                startSpawnTime="50"
                spawnTimeInc="5">
            <!--After the waves end, generator kicks in and generates waves randomly based on 
             the values of included enemies and the total wave value.-->
        </WavesGenerator>

        <Waypoints>
            <Waypoint>10;2</Waypoint>
            <Waypoint>9;2</Waypoint>
            <Waypoint>9;4</Waypoint>
            <Waypoint>6;4</Waypoint>
            <Waypoint>6;5</Waypoint>
            <Waypoint>3;5</Waypoint>
            <Waypoint>3;3</Waypoint>
            <Waypoint>5;3</Waypoint>
            <Waypoint>5;1</Waypoint>
            <Waypoint>1;1</Waypoint>
            <Waypoint>1;3</Waypoint>
            <Waypoint>0;3</Waypoint>
        </Waypoints>
    </Spawner>


    <TowerPositions>

    </TowerPositions>
</Map>
