<?xml version="1.0" encoding="utf-8"?>
<Root>
    <Turrets>
        <!-- barrelTextureAlias XOR barrelAnimationAlias-->
        <!-- firingMode - single (1st fp), random (one of fps at random), rotation (one by one), all-->
        <MachineGun
                barrelAnimationAlias="turret-mg-animation"
                barrelSize="180;90"
                barrelOrigin="135;125"

                carriageTextureAlias="turret_carriage"
                carriageSize="120;120"
                carriageOrigin="100;100"

                reloadTimeMs="100"

                rotationSpeed="120"
                fixateDistance="500"
                firingDistance="400"

                firingPoints="270,-20,-5; 270,-10,-3; 270,0,0; 270,10,3; 270,20,5"
                firingMode="random"
                flashPoints="260,-15; 260,-8; 260,0; 260,8; 260,15"


                projectileAlias="mg_bullet"
                flashAlias="mg_flash"/>
    </Turrets>

    <Projectiles>
        <!--animationAlias XOR textureAlias-->
        <!--customType [homing,..]-->
        <!--aoeRange, aoeDamage-->
        <!--        type="homing"-->
        
        <Projectile
                alias="mg_bullet"
                textureAlias="projectile_bullet"
                size="20;6"
                origin="50;15"
                speed="500"
                flightRange="500"
                directDamage="2"
                hitCircleRadius="5"

                explosionAlias="mg_bullet_explosion"
        />
    </Projectiles>

    <Flashes>
        <Flash
                alias="mg_flash"
                animationAlias="flash-mg-animation-alt"
                size="50;50"
                origin="0;100"
        />

    </Flashes>

    <!--damageDelayMs="xx" (>0)-->
    <Explosions>
        <Explosion
                alias="mg_bullet_explosion"
                animationAlias="explosion-mg-billet-animation"
                size="20;20"
                origin="20;20"/>

    </Explosions>
</Root>
