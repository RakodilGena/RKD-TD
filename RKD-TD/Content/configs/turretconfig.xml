<?xml version="1.0" encoding="utf-8"?>
<Root>
    <Turrets>
        <!-- barrelTextureAlias XOR barrelAnimationAlias-->
        <!-- firingMode - single (1st fp), random (one of fps at random), rotation (one by one), all-->
        <!--aimingMode="predictive" + barrelLenght-->

        <MachineGun
                price="100"

                barrelAnimationAlias="turret-mg-animation"
                barrelSize="200;100"
                barrelOrigin="135;125"

                carriageTextureAlias="turret_carriage"
                carriageSize="130;130"
                carriageOrigin="100;100"

                reloadTimeMs="100"

                rotationSpeed="180"
                fixateDistance="750"
                firingDistance="650"
                projectileFlightRange="750"

                directDamage="8"

                firingPoints="275,-20,-5; 275,-10,-3; 275,0,0; 275,10,3; 275,20,5"
                firingMode="random"
                flashPoints="260,-15; 260,-8; 260,0; 260,8; 260,15"

                aimingMode="predictive"
                barrelLenght="275"

                projectileAlias="mg_bullet"
                flashAlias="mg_flash"/>

        <Shotgun
                price="175"
                barrelTextureAlias="turret_shotgun"
                barrelSize="200;100"
                barrelOrigin="130;94"

                carriageTextureAlias="turret_carriage"
                carriageSize="140;140"
                carriageOrigin="100;100"

                reloadTimeMs="1500"

                rotationSpeed="140"
                fixateDistance="550"
                firingDistance="480"
                projectileFlightRange="550"

                directDamage="14"

                firingPoints="285,-5,-10;  285,-3,-5;  285,0,0;  285,3,5;  285,5,10"
                firingMode="all"
                flashPoints="280,0; 280,0; 280,0; 280,0; 280,0"

                aimingMode="predictive"
                barrelLenght="285"

                projectileAlias="shotgun_bullet"
                flashAlias="shotgun_flash"/>

        <Cannon
                price="350"
                barrelTextureAlias="turret_cannon"
                barrelSize="200;100"
                barrelOrigin="150;100"

                carriageTextureAlias="turret_carriage"
                carriageSize="160;160"
                carriageOrigin="100;100"

                reloadTimeMs="3000"

                rotationSpeed="100"
                fixateDistance="1000"
                firingDistance="900"
                projectileFlightRange="1100"

                directDamage="220"
                aoeRange="70"
                aoeDamage="50"

                firingPoints="285,0,0"
                firingMode="single"
                flashPoints="255,0"

                aimingMode="predictive"
                barrelLenght="295"

                projectileAlias="shell"
                flashAlias="cannon_flash"/>

        <Missile
                price="280"
                barrelTextureAlias="turret_missile"
                barrelSize="110;100"
                barrelOrigin="120;105"

                carriageTextureAlias="turret_carriage"
                carriageSize="160;160"
                carriageOrigin="100;100"

                reloadTimeMs="2100"

                rotationSpeed="125"
                fixateDistance="1150"
                firingDistance="1050"
                projectileFlightRange="1250"

                directDamage="30"
                aoeRange="100"
                aoeDamage="90"

                firingPoints="180,-50,0; 180,0,0; 180,58,0;"
                firingMode="rotation"
                flashPoints="170,-50; 170,0; 170,58;"

                projectileAlias="missile"
                flashAlias="missile_launch_flash"/>
    </Turrets>

    <Projectiles>
        <!--animationAlias XOR textureAlias-->
        <!--aoeRange, aoeDamage-->
        <!--        type="homing"-->
        <!--        trailFlashAlias, trailFlashSpawnPauseMs, trailFlashSpawnOffset-->
        <Projectile
                alias="mg_bullet"
                textureAlias="projectile_bullet"
                size="25;8"
                origin="50;15"
                speed="600"

                hitCircleRadius="6"

                explosionAlias="mg_bullet_explosion"
        />

        <Projectile
                alias="shotgun_bullet"
                textureAlias="projectile_bullet"
                size="30;9"
                origin="50;15"
                speed="600"

                hitCircleRadius="8"

                explosionAlias="shotgun_bullet_explosion"
        />

        <Projectile
                alias="shell"
                textureAlias="projectile_shell"
                size="55;28"
                origin="65;48"
                speed="750"

                hitCircleRadius="24"

                explosionAlias="shell_explosion"
        />

        <Projectile
                alias="missile"
                animationAlias="projectile-missile-animation"
                size="80;35"
                origin="145;67"
                speed="820"

                hitCircleRadius="15"
                type="homing"

                explosionAlias="missile_explosion"

                trailFlashAlias="missile_fly_flash"
                trailFlashSpawnPauseMs="30"
                trailFlashSpawnOffset="-70;0"
        />
    </Projectiles>

    <Flashes>
        <Flash
                alias="mg_flash"
                animationAlias="flash-mg-animation"
                size="55;55"
                origin="0;100"/>

        <Flash
                alias="shotgun_flash"
                animationAlias="flash-shotgun-animation"
                size="70;80"
                origin="0;100"/>

        <Flash
                alias="cannon_flash"
                animationAlias="flash-cannon-animation"
                size="150;150"
                origin="0;100"/>

        <Flash
                alias="missile_launch_flash"
                animationAlias="flash-missile-launch-animation"
                size="70;70"
                origin="92;100"/>

        <Flash
                alias="missile_fly_flash"
                animationAlias="flash-missile-fly-animation"
                size="30;30"
                origin="50;50"/>

    </Flashes>

    <!--damageDelayMs="xx" (>0)-->
    <Explosions>
        <Explosion
                alias="mg_bullet_explosion"

                animationAlias="explosion-bullet-animation"
                origin="20;20"

                size="23;23"/>

        <Explosion
                alias="shotgun_bullet_explosion"

                animationAlias="explosion-bullet-animation"
                origin="20;20"

                size="28;28"/>

        <Explosion
                alias="shell_explosion"

                animationAlias="explosion-shell-animation"
                origin="150;150"

                size="210;210"
                damageDelayMs="100"/>

        <Explosion
                alias="missile_explosion"

                animationAlias="explosion-missile-animation"
                origin="200;200"

                size="220;220"
                damageDelayMs="120"/>

    </Explosions>
</Root>
