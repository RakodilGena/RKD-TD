<?xml version="1.0" encoding="utf-8"?>
<Root>
    <Turrets>
        <!-- barrelTextureAlias XOR barrelAnimationAlias-->
        <!-- firingMode - single (1st fp), random (one of fps at random), rotation (one by one), all-->
        <!--aimingMode="predictive" + barrelLenght-->

        <MachineGun
                price="100"

                barrelAnimationAlias="turret-mg-animation"
                barrelSize="200;100"
                barrelOrigin="135;125"

                carriageTextureAlias="turret_carriage"
                carriageSize="140;140"
                carriageOrigin="100;100"

                reloadTimeMs="100"

                rotationSpeed="180"
                fixateDistance="750"
                firingDistance="700"
                projectileFlightRange="750"

                directDamage="2"

                firingPoints="275,-20,-5; 275,-10,-3; 275,0,0; 275,10,3; 275,20,5"
                firingMode="random"
                flashPoints="260,-15; 260,-8; 260,0; 260,8; 260,15"

                aimingMode="predictive"
                barrelLenght="275"

                projectileAlias="mg_bullet"
                flashAlias="mg_flash"/>

        <Shotgun
                price="150"
                barrelTextureAlias="turret_shotgun"
                barrelSize="200;100"
                barrelOrigin="140;94"

                carriageTextureAlias="turret_carriage"
                carriageSize="150;150"
                carriageOrigin="100;100"

                reloadTimeMs="1500"

                rotationSpeed="140"
                fixateDistance="550"
                firingDistance="500"
                projectileFlightRange="450"
                
                directDamage="5"

                firingPoints="275,-5,-10;  275,-3,-5;  275,0,0;  275,3,5;  275,5,10"
                firingMode="all"
                flashPoints="270,0; 270,0; 270,0; 270,0; 270,0"

                aimingMode="predictive"
                barrelLenght="275"

                projectileAlias="shotgun_bullet"
                flashAlias="shotgun_flash"/>

        <Cannon
                price="400"
                barrelTextureAlias="turret_cannon"
                barrelSize="200;100"
                barrelOrigin="150;100"

                carriageTextureAlias="turret_carriage"
                carriageSize="160;160"
                carriageOrigin="100;100"

                reloadTimeMs="3000"

                rotationSpeed="100"
                fixateDistance="850"
                firingDistance="800"
                projectileFlightRange="850"

                directDamage="55"
                aoeRange="58"
                aoeDamage="20"

                firingPoints="295,0,0"
                firingMode="single"
                flashPoints="255,0"

                aimingMode="predictive"
                barrelLenght="295"

                projectileAlias="shell"
                flashAlias="cannon_flash"/>

        <Missile
                price="300"
                barrelTextureAlias="turret_missile"
                barrelSize="130;120"
                barrelOrigin="130;100"

                carriageTextureAlias="turret_carriage"
                carriageSize="145;145"
                carriageOrigin="100;100"

                reloadTimeMs="2100"

                rotationSpeed="125"
                fixateDistance="1000"
                firingDistance="950"
                projectileFlightRange="1100"

                directDamage="10"
                aoeRange="80"
                aoeDamage="45"

                firingPoints="190,-55,0; 190,0,0; 190,53,0;"
                firingMode="rotation"
                flashPoints="160,-55; 160,0; 160,53;"

                projectileAlias="missile"
                flashAlias="missile_launch_flash"/>
    </Turrets>

    <Projectiles>
        <!--animationAlias XOR textureAlias-->
        <!--aoeRange, aoeDamage-->
        <!--        type="homing"-->
        <!--        trailFlashAlias, trailFlashSpawnPauseMs, trailFlashSpawnOffset-->
        <Projectile
                alias="mg_bullet"
                textureAlias="projectile_bullet"
                size="25;8"
                origin="50;15"
                speed="500"

                hitCircleRadius="6"

                explosionAlias="mg_bullet_explosion"
        />

        <Projectile
                alias="shotgun_bullet"
                textureAlias="projectile_bullet"
                size="30;9"
                origin="50;15"
                speed="500"
                
                hitCircleRadius="8"                

                explosionAlias="shotgun_bullet_explosion"
        />

        <Projectile
                alias="shell"
                textureAlias="projectile_shell"
                size="55;28"
                origin="115;48"
                speed="650"

                hitCircleRadius="24"

                explosionAlias="shell_explosion"
        />

        <Projectile
                alias="missile"
                animationAlias="projectile-missile-animation"
                size="80;35"
                origin="195;67"
                speed="630"

                hitCircleRadius="20"
                type="homing"

                explosionAlias="missile_explosion"

                trailFlashAlias="missile_fly_flash"
                trailFlashSpawnPauseMs="30"
                trailFlashSpawnOffset="-70;0"
        />
    </Projectiles>

    <Flashes>
        <Flash
                alias="mg_flash"
                animationAlias="flash-mg-animation"
                size="55;55"
                origin="0;100"/>

        <Flash
                alias="shotgun_flash"
                animationAlias="flash-shotgun-animation"
                size="70;80"
                origin="0;100"/>

        <Flash
                alias="cannon_flash"
                animationAlias="flash-cannon-animation"
                size="150;150"
                origin="0;100"/>

        <Flash
                alias="missile_launch_flash"
                animationAlias="flash-missile-launch-animation"
                size="70;70"
                origin="92;100"/>

        <Flash
                alias="missile_fly_flash"
                animationAlias="flash-missile-fly-animation"
                size="30;30"
                origin="50;50"/>

    </Flashes>

    <!--damageDelayMs="xx" (>0)-->
    <Explosions>
        <Explosion
                alias="mg_bullet_explosion"

                animationAlias="explosion-bullet-animation"
                origin="20;20"

                size="23;23"/>

        <Explosion
                alias="shotgun_bullet_explosion"

                animationAlias="explosion-bullet-animation"
                origin="20;20"

                size="28;28"/>

        <Explosion
                alias="shell_explosion"

                animationAlias="explosion-shell-animation"
                origin="150;150"

                size="190;190"
                damageDelayMs="100"/>

        <Explosion
                alias="missile_explosion"

                animationAlias="explosion-missile-animation"
                origin="200;200"

                size="210;210"
                damageDelayMs="120"/>

    </Explosions>
</Root>
